data/*
# ... except the tiny committed synthetic object and the placeholder.
!data/.gitkeep
!data/mock.h5ad

# Belt-and-suspenders: ignore any .h5ad anywhere except the committed mock.
*.h5ad
!data/mock.h5ad

# The real canonical object and extracted CSVs are shared out of band (Drive),
# never via git.
data/locale.h5ad
data/raw/

