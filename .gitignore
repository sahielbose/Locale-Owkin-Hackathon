# --- Data is NOT committed (see CLAUDE.md "Data-not-in-git rules") ---
# Ignore everything under data/ ...
data/*
# ... except the tiny committed synthetic object and the placeholder.
!data/.gitkeep
!data/mock.h5ad

# Belt-and-suspenders: ignore any .h5ad anywhere except the committed mock.
*.h5ad
!data/mock.h5ad

# The real canonical object and extracted CSVs are shared out of band (Drive),
# never via git.
data/locale.h5ad
data/raw/

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Generated viz sample (regenerate with `python -m src.locale.viz.payload`) ---
src/locale/viz/app/sample_payload.js
src/locale/viz/app/sample_payload.json
src/localespatial/viz/app/viz_bundle.js
src/localespatial/viz/app/dashboard_data.js

# --- 3D hero assets: fetched externally, never committed (see assets/ASSETS.md) ---
# Everything under assets/ is generated by scripts/fetch_assets.py except ASSETS.md.
src/locale/viz/app/assets/*
!src/locale/viz/app/assets/ASSETS.md

# --- Secrets ---
.env
.env.*

